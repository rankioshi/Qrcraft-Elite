{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Private user profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "QRCode": {
      "title": "QR Code Configuration",
      "description": "A saved QR code configuration",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "data": { "type": "string" },
        "config": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "data", "config"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/qr_codes/{qrCodeId}": {
      "schema": "QRCode",
      "description": "Saved QR code configurations"
    }
  }
}
